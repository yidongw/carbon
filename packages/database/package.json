{
  "name": "@carbon/database",
  "devDependencies": {
    "@carbon/config": "workspace:*",
    "@supabase/supabase-js": "catalog:",
    "@types/node": "20.19.39",
    "@types/pg": "8.15.6",
    "@types/uuid": "8.3.4",
    "dotenv": "16.3.1",
    "npm-run-all": "catalog:",
    "rimraf": "catalog:",
    "supabase": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "uuid": "9.0.0"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./event": "./src/event.ts",
    "./ratelimit": "./src/ratelimit.ts",
    "./audit": "./src/audit.ts",
    "./audit.config": "./src/audit.config.ts",
    "./audit.types": "./src/audit.types.ts",
    "./swagger-docs-schema": "./src/swagger-docs-schema.ts"
  },
  "private": true,
  "scripts": {
    "clean": "rimraf .turbo node_modules dist",
    "db:function:new": "supabase functions new",
    "db:init": "supabase init",
    "db:migrate:new": "supabase migration new",
    "db:seed": "tsx src/seed.ts",
    "db:seed:dev": "tsx src/seed-dev.ts",
    "deploy": "supabase link --project-ref $SUPABASE_PROJECT_ID && supabase db push",
    "lint": "biome lint --write ",
    "typecheck": "tsgo --noEmit"
  },
  "sideEffects": false,
  "version": "0.0.0",
  "dependencies": {
    "@supabase/postgrest-js": "catalog:",
    "cookie": "catalog:",
    "dompurify": "catalog:",
    "kysely": "catalog:",
    "kysely-supabase": "0.2.1",
    "nanoid": "catalog:",
    "pg": "8.20.0",
    "react-pdf": "catalog:",
    "sst": "catalog:",
    "zod": "catalog:"
  }
}
