{
  "name": "@carbon/stripe",
  "dependencies": {
    "@carbon/auth": "workspace:*",
    "@carbon/database": "workspace:*",
    "@carbon/env": "workspace:*",
    "@carbon/kv": "workspace:*",
    "@carbon/lib": "workspace:*",
    "@carbon/utils": "workspace:*",
    "@supabase/supabase-js": "catalog:",
    "stripe": "18.5.0"
  },
  "type": "module",
  "devDependencies": {
    "@carbon/config": "workspace:*",
    "@types/node": "20.19.39",
    "dotenv": "16.3.1",
    "rimraf": "catalog:",
    "sst": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "zod": "catalog:"
  },
  "exports": {
    "./stripe.server": "./src/stripe.server.ts"
  },
  "private": true,
  "scripts": {
    "clean": "rimraf .turbo node_modules dist",
    "dev": "tsup --watch",
    "lint": "biome lint --write ",
    "dev:stripe": "tsx ./stripe.dev.ts",
    "register:stripe": "tsx ./stripe.register.ts",
    "typecheck": "tsgo --noEmit"
  },
  "sideEffects": false,
  "version": "0.0.0"
}
