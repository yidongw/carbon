msgid "<0>insert</0> lets you insert into your tables. You can also insert in bulk and do UPSERT."
msgstr "<0>insert</0> pozwala wstawiać dane do tabel. Możesz również wstawiać zbiorczo i wykonywać operacje UPSERT."

msgid "<0>insert</0> will also return the replaced values for UPSERT."
msgstr "<0>insert</0> zwróci również zastąpione wartości dla UPSERT."

msgid "<0>update</0> lets you update rows. <1>update</1> will match all rows by default. You can update specific rows using horizontal filters, e.g. <2>eq</2>, <3>lt</3>, and <4>is</4>."
msgstr "<0>update</0> pozwala na aktualizowanie wierszy. <1>update</1> domyślnie będzie pasować do wszystkich wierszy. Możesz aktualizować określone wiersze za pomocą filtrów poziomych, np. <2>eq</2>, <3>lt</3> i <4>is</4>."

msgid "<0>update</0> will also return the replaced values for UPDATE."
msgstr "<0>update</0> zwróci również zastąpione wartości dla UPDATE."

