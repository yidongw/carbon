msgid "<0>delete</0> lets you delete rows. <1>delete</1> will match all rows by default, so remember to specify your filters!"
msgstr "<0>delete</0> ti permette di eliminare righe. <1>delete</1> corrisponderà a tutte le righe per impostazione predefinita, quindi ricordati di specificare i tuoi filtri!"

msgid "<0>insert</0> lets you insert into your tables. You can also insert in bulk and do UPSERT."
msgstr "<0>insert</0> ti consente di inserire dati nelle tue tabelle. Puoi anche inserire in blocco ed eseguire UPSERT."

msgid "<0>insert</0> will also return the replaced values for UPSERT."
msgstr "<0>insert</0> restituirà anche i valori sostituiti per UPSERT."

msgid "<0>update</0> lets you update rows. <1>update</1> will match all rows by default. You can update specific rows using horizontal filters, e.g. <2>eq</2>, <3>lt</3>, and <4>is</4>."
msgstr "<0>update</0> ti consente di aggiornare le righe. <1>update</1> corrisponderà a tutte le righe per impostazione predefinita. Puoi aggiornare righe specifiche utilizzando filtri orizzontali, ad es. <2>eq</2>, <3>lt</3> e <4>is</4>."

msgid "<0>update</0> will also return the replaced values for UPDATE."
msgstr "<0>update</0> restituirà anche i valori sostituiti per UPDATE."

