msgid "<0>delete</0> lets you delete rows. <1>delete</1> will match all rows by default, so remember to specify your filters!"
msgstr "<0>delete</0> vous permet de supprimer des lignes. <1>delete</1> correspondra à toutes les lignes par défaut, alors n'oubliez pas de spécifier vos filtres !"

msgid "<0>insert</0> lets you insert into your tables. You can also insert in bulk and do UPSERT."
msgstr "<0>insert</0> vous permet d'insérer des données dans vos tables. Vous pouvez également insérer en masse et effectuer des UPSERT."

msgid "<0>insert</0> will also return the replaced values for UPSERT."
msgstr "<0>insert</0> retournera également les valeurs remplacées pour UPSERT."

msgid "<0>update</0> lets you update rows. <1>update</1> will match all rows by default. You can update specific rows using horizontal filters, e.g. <2>eq</2>, <3>lt</3>, and <4>is</4>."
msgstr "<0>update</0> vous permet de mettre à jour des lignes. <1>update</1> correspondra à toutes les lignes par défaut. Vous pouvez mettre à jour des lignes spécifiques en utilisant des filtres horizontaux, par exemple <2>eq</2>, <3>lt</3>, et <4>is</4>."

msgid "<0>update</0> will also return the replaced values for UPDATE."
msgstr "<0>update</0> retournera également les valeurs remplacées pour UPDATE."

