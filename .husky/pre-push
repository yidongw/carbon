#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Husky sets core.hooksPath=.husky, so git ignores .git/hooks/*.
# Delegate to the local, untracked translation hook if present. Keeping the
# heavy logic (pnpm run translate via ollama) in .git/hooks/pre-push makes it
# opt-in per machine — devs without it just push normally.
# Use --git-dir (not --git-path, which honors core.hooksPath and would point
# back here, causing infinite recursion).
hook="$(git rev-parse --git-dir)/hooks/pre-push"
[ -x "$hook" ] && exec "$hook" "$@"
exit 0
