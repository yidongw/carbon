#!/bin/sh
# Fresh git worktrees / clones lack .husky/_/ until `pnpm install` runs its
# prepare script. Without this guard the hook crashes with a cryptic
# ".husky/_/husky.sh: No such file or directory". Skip hooks gracefully instead.
if [ ! -f "$(dirname "$0")/_/husky.sh" ]; then
    echo "⚠ husky not initialized — run 'pnpm install'. Skipping git hooks."
    exit 0
fi
. "$(dirname "$0")/_/husky.sh"

pnpm exec lint-staged

# Compile lingui translations if any relevant files were modified
if git diff --cached --name-only | grep -qE '\.(tsx?|jsx?)$|\.po$'; then
    echo "Compiling translations..."
    pnpm lingui:check

    # Strip `#:` origin refs (file locations) before committing — they shift on
    # any code edit and are the biggest .po diff / PR-conflict source. They're
    # kept in the working dir during the translate flow (needed for LLM context)
    # and only stripped right before commit.
    pnpm lingui:clean

    # Add compiled locale files to the commit
    git add packages/locale/locales/**/*.po
fi

# Regenerate MCP tools if any .service.ts file was modified
if git diff --cached --name-only | grep -q '\.service\.ts$'; then
    npx tsx scripts/generate-mcp.ts
    git add apps/erp/app/routes/api+/mcp+/lib/tool-metadata.json
fi
