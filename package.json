{
  "name": "carbon",
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@lingui/cli": "catalog:",
    "@react-router/dev": "catalog:",
    "@types/aws-lambda": "8.10.152",
    "@typescript/native-preview": "7.0.0-dev.20260409.1",
    "csv-parse": "5.6.0",
    "husky": "8.0.3",
    "lint-staged": "16.4.0",
    "npm-run-all": "catalog:",
    "postcss-nesting": "12.1.5",
    "rimraf": "catalog:",
    "supabase": "catalog:",
    "ts-morph": "22.0.0",
    "tsx": "catalog:",
    "turbo": "2.9.6",
    "typescript": "catalog:",
    "vite-plugin-babel-macros": "catalog:"
  },
  "lint-staged": {
    "(apps|packages)/**/*.{js,ts,jsx,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.json": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:erp": "turbo run build --filter=erp",
    "build:mes": "turbo run build --filter=mes",
    "ci:migrations": "pnpm --filter ci ci:migrations",
    "ci:deploy": "pnpm --filter ci ci:deploy",
    "clean": "turbo run clean && rimraf ./node_modules && rimraf ./pnpm-lock.yaml",
    "db:build": "run-s db:kill db:start setup",
    "db:function:new": "pnpm --filter @carbon/database db:function:new",
    "db:kill": "pnpm --filter @carbon/database db:kill",
    "db:kill:redis": "pnpm --filter @carbon/kv db:kill",
    "db:migrate": "pnpm --filter @carbon/database db:migrate",
    "db:migrate:force": "turbo run db:migrate:force --no-cache",
    "db:migrate:new": "pnpm --filter @carbon/database db:migrate:new",
    "db:pull": "turbo run db:pull",
    "db:push": "turbo run db:push",
    "db:restart": "run-s db:stop db:start",
    "db:seed": "turbo run db:seed --no-cache",
    "db:seed:dev": "pnpm --filter @carbon/database db:seed:dev --",
    "db:start": "pnpm --filter @carbon/database db:start",
    "db:start:redis": "pnpm --filter @carbon/kv db:start",
    "db:stop": "pnpm --filter @carbon/database db:stop",
    "db:types": "pnpm --filter @carbon/database db:types",
    "deploy": "turbo run deploy",
    "dev": "run-p dev:docker dev:jobs dev:jobs-wait",
    "dev:docker": "docker compose up -d redis || docker-compose up -d redis",
    "dev:jobs-wait": "pnpm dlx wait-on tcp:8288 && run-p dev:erp dev:stripe",
    "dev:academy": "turbo run dev --filter=./apps/academy --filter=./packages/",
    "dev:erp": "turbo run dev --filter=./apps/erp --filter=./packages/ ",
    "dev:jobs": "pnpm --filter @carbon/jobs dev:jobs",
    "dev:mes": "turbo run dev --filter=./apps/mes",
    "dev:packages": "turbo run dev --filter=./packages/*",
    "dev:starter": "turbo run dev --filter=./apps/starter --filter=./packages/",
    "dev:stripe": "pnpm --filter @carbon/stripe dev:stripe",
    "format": "biome format --write",
    "generate:mcp": "tsx scripts/generate-mcp.ts",
    "generate:swagger": "tsx scripts/generate-swagger-docs.ts && pnpm exec biome format ./packages/database/src/swagger-docs-schema.ts --write --files-max-size=5000000",
    "generate:types": "tsx scripts/generate-db-types.ts",
    "lint": "turbo run lint",
    "lingui:check": "pnpm run lingui:extract && pnpm run lingui:compile",
    "lingui:compile": "lingui compile --namespace es",
    "lingui:extract": "lingui extract --clean",
    "novu:sync": "pnpm dlx novu@latest sync --bridge-url https://app.carbon.ms/api/novu --secret-key $NOVU_SECRET_KEY --api-url https://api.novu.co",
    "postdb:build": "run-s generate:types generate:swagger",
    "predb:build": "tsx scripts/setup-env-files.ts",
    "prepare": "pnpm exec husky install",
    "setup": "turbo run setup",
    "test": "turbo run test",
    "tool:new": "tsx scripts/create-tool.ts",
    "translate": "pnpm dlx linguito translate --llm",
    "agent:new": "tsx scripts/create-agent.ts",
    "types": "turbo run types",
    "typecheck": "turbo run typecheck --filter='*'",
    "typegen": "turbo run typegen"
  },
  "workspaces": [
    "apps/*",
    "ci",
    "examples/*",
    "packages/*"
  ],
  "packageManager": "pnpm@10.13.1+sha512.37ebf1a5c7a30d5fabe0c5df44ee8da4c965ca0c5af3dbab28c3a1681b70a256218d05c81c9c0dcf767ef6b8551eb5b960042b9ed4300c59242336377e01cfad",
  "dependencies": {
    "@opentelemetry/semantic-conventions": "1.40.0",
    "@react-router/remix-routes-option-adapter": "catalog:",
    "cookie": "catalog:",
    "dompurify": "catalog:",
    "fast-uri": "3.1.0",
    "fdir": "6.5.0",
    "nanoid": "catalog:",
    "react-pdf": "catalog:",
    "remix-flat-routes": "catalog:",
    "sst": "catalog:",
    "tsup": "catalog:"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@swc/core",
      "@tailwindcss/oxide",
      "core-js",
      "esbuild",
      "protobufjs",
      "supabase"
    ],
    "patchedDependencies": {
      "@ai-sdk-tools/store@1.2.0": "patches/@ai-sdk-tools__store@1.2.0.patch",
      "@react-router/dev@7.12.0": "patches/@react-router__dev@7.12.0.patch"
    }
  }
}
