{
  "$schema": "https://turborepo.org/schema.json",
  "globalEnv": ["VERCEL", "VERCEL_ENV", "VERCEL_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "//#lingui:compile"],
      "env": ["VERCEL", "VERCEL_ENV", "VERCEL_URL", "VERCEL_DEPLOYMENT_ID"],
      "passThroughEnv": [
        "VERCEL",
        "VERCEL_ENV",
        "VERCEL_URL",
        "VERCEL_DEPLOYMENT_ID",
        "VERCEL_PROJECT_PRODUCTION_URL",
        "VERCEL_GIT_COMMIT_REF"
      ],
      "outputs": [
        "dist/**",
        "build/**",
        "api/**",
        ".vercel/**",
        "public/build/**",
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "//#lingui:compile": {
      "inputs": [
        "lingui.config.js",
        "apps/erp/app/**",
        "apps/mes/app/**",
        "packages/react/src/**",
        "packages/locale/locales/**/*.po"
      ],
      "outputs": ["packages/locale/locales/**/*.mjs"]
    },
    "test": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "cache": false,
      "dependsOn": []
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "deploy": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "db:types": {
      "outputs": [],
      "cache": true
    },
    "db:init": {
      "outputs": []
    },
    "db:migrate": {
      "outputs": [],
      "cache": false
    },
    "db:seed": {
      "outputs": [],
      "cache": false
    },
    "typegen": {
      "cache": false,
      "outputs": []
    }
  }
}
