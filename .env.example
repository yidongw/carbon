# Copy to `.env` and fill in your secrets.
#
# For local dev, ports/URLs/Supabase keys/Redis/Inngest are auto-generated into
# `.env.local` by `crbn up` (see packages/dev/src/commands/up.ts). Vite/React Router
# auto-load `.env.local` on top of `.env`, so you only need to set genuine
# secrets in this file (OAuth, Stripe, Resend, etc.). Leave port/URL/Supabase
# variables out — `.env.local` will provide them.

# Carbon
AUTH_PROVIDERS="email,google" # "email" | "google" | "azure" | "wechat"
CARBON_EDITION="community" # "community" | "cloud" | "enterprise"
SESSION_SECRET="************************"
RATE_LIMIT="5"

# Supabase OAuth (client IDs/secrets from your provider; redirect URIs come from .env.local)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID="************.apps.googleusercontent.com"
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET="GOCSPX-****************************"
SUPABASE_AUTH_EXTERNAL_AZURE_CLIENT_ID="***************************************"
SUPABASE_AUTH_EXTERNAL_AZURE_CLIENT_SECRET="***********************************"

# WeChat (公众号/MP — a free 测试号 works for dev). Add "wechat" to AUTH_PROVIDERS
# to show the in-app "Sign in with WeChat" button and the desktop QR-scan login.
WECHAT_MP_APP_ID="wx****************"
WECHAT_MP_APP_SECRET="********************************"
WECHAT_WEBHOOK_TOKEN="********************" # 接口配置信息 Token; also set its URL to https://<your-host>/api/webhook/wechat for QR-scan event push
# In-app OAuth callback is derived from the request origin (https://<host>/auth/wechat-callback);
# no env var needed — just register that host under the account's 网页授权域名.

# Phone SMS OTP login via Aliyun 号码认证服务 (Dypnsapi). Add "phone" to
# AUTH_PROVIDERS to show the phone sign-in tab. The verification-code service ships
# 赠送 (gifted) signatures + templates (no ICP/template approval). Use an approved
# (审核通过) signature and a login template; template 100001 ("您的验证码为${code}…
# ${min}分钟内有效") expects both `code` and `min` variables — both are sent.
# The RAM user/AccessKey needs the AliyunDypnsFullAccess policy. Mainland-China only.
ALIBABA_CLOUD_ACCESS_KEY_ID="LTAI****************"
ALIBABA_CLOUD_ACCESS_KEY_SECRET="********************************"
ALIBABA_CLOUD_SMS_SIGN_NAME="速通互联验证码"
ALIBABA_CLOUD_SMS_TEMPLATE_CODE="100001"

# Posthog
POSTHOG_API_HOST="https://us.posthog.com"
POSTHOG_PROJECT_PUBLIC_KEY="********************"

# Stripe
STRIPE_SECRET_KEY="sk_test_*************"
STRIPE_WEBHOOK_SECRET="whsec_************"

# GTM (notifications fan-out)
GTM_EVENTS_API_SECRET_KEY=""

# Resend
RESEND_API_KEY="************************"
RESEND_DOMAIN="carbon.ms"
# RESEND_AUDIENCE_ID="*****" # Optional — required for contact management in `packages/jobs`

# Novu
NOVU_APPLICATION_ID="********************"
NOVU_SECRET_KEY="********************"

# Inngest (production keys; dev mode flags are in .env.local)
# INNGEST_SIGNING_KEY="signkey-****-********************"
# INNGEST_EVENT_KEY="********************"

# Cloudflare
CLOUDFLARE_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
CLOUDFLARE_TURNSTILE_SECRET_KEY="********************"

# Slack
SLACK_BOT_TOKEN="***********************"

# AI
ANTHROPIC_API_KEY="sk-ant-***************"
OPENAI_API_KEY="sk-proj-*****************"

# Google Places
GOOGLE_PLACES_API_KEY="*******************"
